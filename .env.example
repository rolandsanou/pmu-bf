# Database
DATABASE_URL="postgresql://pmu:pmu@localhost:5433/pmu?schema=public"

# Operator dashboard
OPERATOR_PASSWORD="change-me"
OPERATOR_SESSION_SECRET="generate-a-long-random-string"

# Payment numbers shown to customers (operator's mobile money)
NEXT_PUBLIC_BUSINESS_NAME="Pari Express"
NEXT_PUBLIC_PAYMENT_NAME="Nom du compte"
