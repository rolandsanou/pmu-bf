# Object storage for ticket photos (production).
# Leave blank in dev to use local disk (public/uploads). Required on Render/Vercel.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
